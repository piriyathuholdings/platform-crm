# Copy to docker-compose.env (or set in Coolify) — do not commit real values.

POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me

# Full SQLAlchemy URL for the api service (compose service name: postgres)
DATABASE_URL=postgresql+psycopg://crm:change-me@postgres:5432/crm

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

NEXTJS_ORIGIN=https://crm.piriyathu.com
ACCESS_COOKIE_NAME=crm_access_token
